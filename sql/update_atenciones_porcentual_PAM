UPDATE ppto_2025 p
INNER JOIN cons_atenciones2025_ppam s ON p.ubigeo = s.ubigeo
SET 
    p.MONTO_PIA_PAMT = p.TOTAL_MONTO_PIA * (s.PORCENTAJE_PAM / 100.0),
    p.MONTO_PIM_PAMT = p.TOTAL_MONTO_PIM * (s.PORCENTAJE_PAM / 100.0),
    p.MONTO_DEVENGADO_PAMT = p.TOTAL_MONTO_DEVENGADO * (s.PORCENTAJE_PAM / 100.0)
WHERE p.FUNCION="20"
  AND p.CATEGORIA_GASTO = 5;
