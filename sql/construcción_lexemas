    # Verificación para que se inicie exactamente ahí (\b) y termine ahí (\b) o permita sufijos válidos (\w*)
    # pero asegurando que no haya letras pegadas antes de la palabra (como 'dis' en dispension)
    patrones_absolutos_dinamicos.append(rf"\b{re.escape(t_limpio)}\w*\b")

regex_absolutos = re.compile("|".join(patrones_absolutos_dinamicos), re.IGNORECASE)
