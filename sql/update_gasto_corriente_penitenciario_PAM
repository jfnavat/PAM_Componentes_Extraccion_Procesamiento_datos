UPDATE ppto_2025 p
INNER JOIN inpe2025_ppam s ON p.ubigeo = s.ubigeo
SET 
    p.MONTO_PIA_PAMT = p.TOTAL_MONTO_PIA * (s.PORC_ADULTOS_MAYORES / 100.0),
    p.MONTO_PIM_PAMT = p.TOTAL_MONTO_PIM * (s.PORC_ADULTOS_MAYORES / 100.0),
    p.MONTO_DEVENGADO_PAMT = p.TOTAL_MONTO_DEVENGADO * (s.PORC_ADULTOS_MAYORES / 100.0),
		USADO = 1;
WHERE p.FUNCION="06"  /* JUSTICIA */
  AND p.PLIEGO="061" /* INPE */
  AND p.CATEGORIA_GASTO = 5 AND USADO=0;
