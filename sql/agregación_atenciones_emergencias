SELECT 
    `PERIODO`, `UBIGEO`, `DEPARTAMENTO`, `PROVINCIA`, `DISTRITO`,
    CASE 
        WHEN `EDAD` = 15 THEN '60 O MÁS AÑOS'
        ELSE 'OTRAS EDADES'
    END AS GRUPO_ETARIO,
    SUM(`NRO_TOTAL_ATENCIONES`) AS TOTAL_ATENCIONES,
    ROUND (
        (SUM(`NRO_TOTAL_ATENCIONES`) / SUM(SUM(`NRO_TOTAL_ATENCIONES`)) OVER (PARTITION BY `PERIODO`, `UBIGEO`)) * 100, 2) 
AS PORCENTAJE_ATENCIONES
FROM `ate_emergencias2025`
GROUP BY 
    `UBIGEO`,
    CASE 
        WHEN `EDAD` = 15 THEN '60 O MÁS AÑOS'
        ELSE 'OTRAS EDADES'
    END
ORDER BY 
    `UBIGEO` ASC, `GRUPO_ETARIO` DESC;
