UPDATE ppto_2025 p
INNER JOIN conadis2025ppam s ON p.ubigeo = s.ubigeo
SET 
    p.MONTO_PIA_PAMT = p.TOTAL_MONTO_PIA * (s.PORCENTAJE_60_MAS / 100.0),
    p.MONTO_PIM_PAMT = p.TOTAL_MONTO_PIM * (s.PORCENTAJE_60_MAS / 100.0),
    p.MONTO_DEVENGADO_PAMT = p.TOTAL_MONTO_DEVENGADO * (s.PORCENTAJE_60_MAS / 100.0),
    p.USADO = 1
WHERE p.PLIEGO = "345"       -- CONADIS
  AND p.CATEGORIA_GASTO = 5  -- Gasto Corriente
  AND p.USADO = 0;
