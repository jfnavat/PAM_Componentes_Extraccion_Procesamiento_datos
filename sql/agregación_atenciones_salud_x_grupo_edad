SELECT 
    `AÑO`, `UBIGEO_DISTRITO` AS UBIGEO, 
    `REGION`,`PROVINCIA`, `DISTRITO`,
    CASE 
        WHEN `GRUPO_EDAD` = '60 - MAS AÑOS' THEN '60 - MAS AÑOS'
        ELSE 'OTROS GRUPOS'
    END AS CATEGORIA_EDAD,
    SUM(`ATENCIONES`) AS TOTAL_ATENCIONES,
    ROUND (
        (SUM(`ATENCIONES`) / SUM(SUM(`ATENCIONES`)) OVER (PARTITION BY `AÑO`, `UBIGEO_DISTRITO`)) * 100, 2) AS PORCENTAJE_ATENCIONES
FROM `sis2025`
GROUP BY 
    `AÑO`, `UBIGEO_DISTRITO`
    CASE 
        WHEN `GRUPO_EDAD` = '60 - MAS AÑOS' THEN '60 - MAS AÑOS'
        ELSE 'OTROS GRUPOS'
    END
ORDER BY 
    `AÑO` DESC, UBIGEO, CATEGORIA_EDAD;
