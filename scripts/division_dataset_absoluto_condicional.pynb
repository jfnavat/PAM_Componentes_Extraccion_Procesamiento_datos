    'FUNCION_NOMBRE', 'DIVISION_FUNCIONAL_NOMBRE', 'GRUPO_FUNCIONAL_NOMBRE', 'META_NOMBRE','CATEGORIA_GASTO_NOMBRE', 'SUBGENERICA_DET_NOMBRE'
]
